# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── MySQL Database (Hostinger → Databases → MySQL) ──────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# ─── Email (Resend — https://resend.com) ─────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
MAIL_FROM=Weasy Express <noreply@yourdomain.com>
MAIL_TO=you@yourdomain.com

# ─── Admin JWT Secret (pick any long random string) ──────────────────────────
ADMIN_SECRET=change-me-to-a-long-random-secret
