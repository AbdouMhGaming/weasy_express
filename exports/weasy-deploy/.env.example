# --- Required ---

# Port the Node.js app should listen on.
# Hostinger usually injects this automatically; otherwise set it to the value
# you configured in the Hostinger Node.js application panel.
PORT=3000

# Resend API key (the same one you used in development).
RESEND_API_KEY=re_your_real_key_here

# --- Optional ---

# From-address Resend will use. Domain must be verified in your Resend account.
MAIL_FROM=Weasy Express <noreply@amongusgenesis.xyz>

# Inbox that receives contact + partner submissions.
MAIL_TO=contact@weasyexpress.com

# Override the static SPA folder path. Defaults to ./public next to the app.
# STATIC_DIR=/home/USER/domains/example.com/public_html/public

# Set to "production" so logs are JSON instead of pretty-printed.
NODE_ENV=production
